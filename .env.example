# ── قواعد البيانات ──
# DATABASE_URL=sqlite:///mazad_plus.db
# DATABASE_URL=postgresql://user:pass@localhost/mazadplus

# ── البريد الإلكتروني (SMTP) ──
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
# MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── رابط التطبيق (مهم للروابط في الإيميلات) ──
APP_URL=http://localhost:5000

# ── مفتاح التشفير (اختياري — يتولد تلقائياً لو فاضي) ──
# SECRET_KEY=
